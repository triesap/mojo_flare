# Pixi
.pixi/
*.lock
# Cargo.lock for the Rust bench baselines is exception-tracked: the
# bench harness runs `cargo build --release --locked` to reproduce
# the exact dep graph the published numbers were measured against.
!benchmark/baselines/*/Cargo.lock
# Cargo.lock for the rustls QUIC FFI cdylib is exception-tracked too:
# the activation script (Track Q2-W commit 2/4) and the
# `build-rustls-quic` pixi task both pass `--locked` to cargo so the
# .so the QUIC server reactor links against is reproducibly built.
!flare/tls/ffi/rustls_wrapper/Cargo.lock

# Mojo build artifacts
__pycache__/
*.pyc
*.mojopkg
.mojo_cache/
.mogg_cache/
.mojo-issues/

# FFI build output (produced by activation script → build/)
build/
# Docs
target/

# Editor
.DS_Store
.idea/
.vscode/
*.swp
.cursor/
.agents/
*.conda

# fuzz artifacts
.mozz_crashes/
fuzz/corpus/

# Benchmark runtime artifacts — everything under results/ is per-run
# output; keep the directory via .gitkeep but don't track contents.
# Exception: published v0.6 multi-worker comparison snapshot is
# tracked so the doc tables can cite a permanent file path.
benchmark/results/*
!benchmark/results/.gitkeep
!benchmark/results/v0.6/
!benchmark/results/v0.6/**
benchmark/baselines/*/server
benchmark/baselines/*/go.sum
benchmark/baselines/*/nginx-rendered.conf
benchmark/baselines/nginx/nginx.pid
benchmark/baselines/nginx/logs/
